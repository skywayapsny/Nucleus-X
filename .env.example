# --- HTTP / white-label ---
# API_TITLE=Inference API
# SERVICE_NAME=my-product

# --- Model (required for inference: path to .gguf) ---
CORE_MODEL_PATH=/path/to/model.gguf

# Optional public name in OpenAI-compatible /v1/models
CORE_PUBLIC_MODEL_ID=local
CORE_API_KEY=
CORE_RATE_LIMIT_RPM=60
CORE_RATE_LIMIT_BURST=10
CORE_ALLOWED_HOSTS=127.0.0.1,localhost

# Sampling & runtime
CORE_TEMPERATURE=0.8
CORE_TOP_P=0.95
CORE_MIN_P=0.05
CORE_N_CTX=2048
CORE_N_BATCH=256
CORE_N_THREADS=0
CORE_N_GPU_LAYERS=0
# CORE_CHAT_FORMAT=chatml

# RAM guard (MB)
CORE_MIN_RAM_MB=500

# Optional: verify file hash (full SHA256 hex)
# CORE_EXPECTED_MODEL_SHA256=

# Optional logit bias (steering); off unless enabled
# CORE_LOGIT_BIAS_ENABLED=0
# CORE_LOGIT_BIAS_PATH=data/config/logit_bias.json
# CORE_LOGIT_BIAS_STRENGTH=

# Stop sequences (comma-separated); defaults are generic
# CORE_STOP_SEQUENCES=

# Shell command matrix (for integrations using security.shell_guards)
# CORE_SHELL_GUARDS_CMD_RUN=1
